{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [':automergeMinor', ':automergeRequireAllStatusChecks'],
  lockFileMaintenance: {
    automerge: true,
    enabled: true
  },
  // クールダウン
  minimumReleaseAge: '7 days',
  // 脆弱性修正は即時
  vulnerabilityAlerts: {
    minimumReleaseAge: null
  }
}
